# Copy to .env and fill in values from CDK stack outputs

# CDK output: SecurityTriageStack > ApiUrl
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# CDK output: SecurityTriageStack > UserPoolId
VITE_USER_POOL_ID=us-east-1_xxxxxxxxx

# CDK output: SecurityTriageStack > UserPoolClientId
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

VITE_REGION=us-east-1

# CDK output: SecurityTriageStack > CognitoDomain
VITE_COGNITO_DOMAIN=security-triage-xxxxxxxxxxxx.auth.us-east-1.amazoncognito.com

# CDK output: FrontendStack > DistributionUrl (include trailing slash)
VITE_REDIRECT_URI=https://xxxxxxxxxxxx.cloudfront.net/
