# Copy to .env.local and fill in values from cdk-outputs.json
#   cp frontend/.env.example frontend/.env.local
# Re-run ./deploy-frontend.sh after any change.

# cdk-outputs.json → SecurityTriageStack → ApiUrl
# Example: https://abc123def4.execute-api.us-east-1.amazonaws.com/prod/
VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod/

# cdk-outputs.json → SecurityTriageStack → UserPoolId
# Example: us-east-1_AbCdEfGhI
VITE_USER_POOL_ID=<region>_<pool-id>

# cdk-outputs.json → SecurityTriageStack → UserPoolClientId
# Example: 1abc2defghijklmnopqrstuvwx
VITE_CLIENT_ID=<cognito-app-client-id>

# cdk-outputs.json → SecurityTriageStack → CognitoDomain  (hostname only — strip the leading https://)
# Example: security-triage-ops.auth.us-east-1.amazoncognito.com
# WARNING: do NOT include https:// — the code adds it automatically
VITE_COGNITO_DOMAIN=<domain-prefix>.auth.<region>.amazoncognito.com
